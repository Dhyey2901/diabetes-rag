# Ollama model used for answer generation
OLLAMA_MODEL=gemma:2b

# Number of retrieved chunks passed to the LLM as context
GEN_TOPK=4

# Retrieval confidence below which the system abstains (0–1)
CONF_ABSTAIN=0.35

# Lexical support overlap below which the generated answer is discarded (0–1)
SUPPORT_THRESHOLD=0.08

# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me
